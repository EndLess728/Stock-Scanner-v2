# ---------- Angel One SmartAPI Credentials ----------
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PASSWORD=your_mpin_or_password_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ---------- Telegram Bot ----------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma separated list of chat IDs (can be users and/or groups)
TELEGRAM_CHAT_IDS=123456789,-100123456789

# ---------- Runtime ----------
LOG_LEVEL=INFO
TZ=Asia/Kolkata
DATABASE_PATH=data/scanner.db
CONFIG_PATH=config/config.yaml
